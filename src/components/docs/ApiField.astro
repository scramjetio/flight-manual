---
import { Badge } from "@/components/ui/badge";

interface Props {
  name: string;
  type: string;
  required?: boolean;
  defaultValue?: string;
}

const { name, type, required = false, defaultValue } = Astro.props;
---

<div class="my-4 border rounded-lg p-4 bg-card text-card-foreground shadow-sm">
  <div class="flex items-center justify-between mb-2">
    <div class="flex items-center gap-2">
      <code class="text-sm font-bold bg-muted px-1.5 py-0.5 rounded text-foreground">{name}</code>
      <span class="text-xs text-muted-foreground font-mono">{type}</span>
    </div>
    <div class="flex items-center gap-2">
      {defaultValue && (
        <span class="text-xs text-muted-foreground">Default: <code class="bg-muted px-1 rounded">{defaultValue}</code></span>
      )}
      {required ? (
        <Badge variant="destructive" className="text-[10px] h-5 uppercase tracking-wider">Required</Badge>
      ) : (
        <Badge variant="secondary" className="text-[10px] h-5 uppercase tracking-wider">Optional</Badge>
      )}
    </div>
  </div>
  <div class="text-sm text-muted-foreground mt-2 prose-sm prose-invert max-w-none">
    <slot />
  </div>
</div>
