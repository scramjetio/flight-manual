---
interface Props {
  title?: string;
}

const { title = "Parameters" } = Astro.props;
---

<div class="my-6">
  <h3 class="text-lg font-semibold mb-3 text-foreground">{title}</h3>
  <div class="border rounded-md overflow-hidden bg-card text-card-foreground shadow-sm">
    <table class="w-full text-sm text-left">
      <slot />
    </table>
  </div>
</div>

<style is:global>
  /* Base styles for tables injected via MDX slot */
  .prose table {
    margin-top: 0 !important;
    margin-bottom: 0 !important;
  }
  .prose thead {
    background-color: hsl(var(--muted) / 0.5);
    border-bottom: 1px solid hsl(var(--border));
  }
  .prose th {
    padding: 0.75rem 1rem;
    font-weight: 500;
    color: hsl(var(--muted-foreground));
  }
  .prose td {
    padding: 0.75rem 1rem;
    border-bottom: 1px solid hsl(var(--border));
  }
  .prose tr:last-child td {
    border-bottom: none;
  }
  .prose tr:hover td {
    background-color: hsl(var(--muted) / 0.3);
  }
</style>
