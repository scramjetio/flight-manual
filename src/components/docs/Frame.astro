---
interface Props {
  caption?: string;
}

const { caption } = Astro.props;
---

<figure class="my-6">
  <div class="relative overflow-hidden rounded-xl border border-border/40 bg-muted/20 p-2 shadow-sm ring-1 ring-inset ring-white/10 dark:ring-white/5">
    <div class="overflow-hidden rounded-lg border border-border/50 bg-background shadow-sm">
      <slot />
    </div>
  </div>
  {caption && (
    <figcaption class="mt-3 text-center text-sm text-muted-foreground">
      {caption}
    </figcaption>
  )}
</figure>
