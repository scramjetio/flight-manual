---
import { AlertTriangle, Info, CheckCircle2, XCircle } from "lucide-react";

interface Props {
  type?: "info" | "warning" | "success" | "danger";
  title?: string;
}

const { type = "info", title } = Astro.props;

const variants = {
  info: {
    classes: "border-blue-500/20 bg-blue-500/5 text-blue-500 [&>svg]:text-blue-500",
    icon: Info,
    defaultTitle: "Note",
  },
  warning: {
    classes: "border-yellow-500/20 bg-yellow-500/5 text-yellow-500 [&>svg]:text-yellow-500",
    icon: AlertTriangle,
    defaultTitle: "Warning",
  },
  success: {
    classes: "border-green-500/20 bg-green-500/5 text-green-500 [&>svg]:text-green-500",
    icon: CheckCircle2,
    defaultTitle: "Success",
  },
  danger: {
    classes: "border-red-500/20 bg-red-500/5 text-red-500 [&>svg]:text-red-500",
    icon: XCircle,
    defaultTitle: "Danger",
  },
};

const config = variants[type];
const Icon = config.icon;
const displayTitle = title || config.defaultTitle;
---

<div class={`relative w-full rounded-lg border p-4 my-6 [&>svg~*]:pl-7 [&>svg+div]:translate-y-[-3px] [&>svg]:absolute [&>svg]:left-4 [&>svg]:top-4 [&>svg]:text-foreground ${config.classes}`}>
  <Icon size={18} />
  <h5 class="mb-1 font-medium leading-none tracking-tight">{displayTitle}</h5>
  <div class="text-sm opacity-90 prose prose-sm dark:prose-invert max-w-none pt-1">
    <slot />
  </div>
</div>
